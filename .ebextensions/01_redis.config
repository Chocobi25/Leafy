packages:
  yum:
    gcc: []
    make: []
    tar: []

commands:
  01_download_redis:
    command: "wget -O /tmp/redis-7.0.15.tar.gz https://download.redis.io/releases/redis-7.0.15.tar.gz"
    test: "test ! -f /tmp/redis-7.0.15.tar.gz"

  02_extract_redis:
    command: "tar xzf /tmp/redis-7.0.15.tar.gz -C /opt/"
    test: "test ! -d /opt/redis-7.0.15"

  03_build_redis:
    command: "make -C /opt/redis-7.0.15"
    test: "test ! -f /opt/redis-7.0.15/src/redis-server"

  04_create_redis_user:
    command: "useradd -r -s /bin/false redis || true"

  05_create_redis_dirs:
    command: "mkdir -p /var/lib/redis /var/log/redis /etc/redis && chown redis:redis /var/lib/redis /var/log/redis"

  06_copy_redis_conf:
    command: |
      cat > /etc/redis/redis.conf << 'EOF'
      bind 127.0.0.1
      protected-mode yes
      port 6379
      daemonize no
      pidfile /var/run/redis_6379.pid
      loglevel notice
      logfile /var/log/redis/redis.log
      databases 16
      dir /var/lib/redis
      maxmemory 100mb
      maxmemory-policy allkeys-lru
      EOF

  07_create_systemd_service:
    command: |
      cat > /etc/systemd/system/redis.service << 'EOF'
      [Unit]
      Description=Redis In-Memory Data Store
      After=network.target

      [Service]
      Type=simple
      User=redis
      Group=redis
      ExecStart=/opt/redis-7.0.15/src/redis-server /etc/redis/redis.conf
      ExecStop=/opt/redis-7.0.15/src/redis-cli shutdown
      Restart=always
      RuntimeDirectory=redis
      RuntimeDirectoryMode=0755

      [Install]
      WantedBy=multi-user.target
      EOF
    test: "test ! -f /etc/systemd/system/redis.service"

  08_enable_and_start_redis:
    command: "systemctl daemon-reload && systemctl enable redis && systemctl start redis"
